{%- assign _t = section.settings.logo_text | strip -%}
{%- if _t == blank -%}
  elaréhair
{%- else -%}
  {%- assign _d = _t | downcase | replace: 'é', 'e' | replace: 'è', 'e' -%}
  {%- if _d == 'privee' or _d == 'prive' or _d == 'elaris 7' or _d == 'elaris7' -%}
    elaréhair
  {%- else -%}
    {{- _t -}}
  {%- endif -%}
{%- endif -%}
