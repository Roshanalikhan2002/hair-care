{% comment %}
  Renders one product card for collection pages (matches home card styling).
  Accepts: product (required), button_label (optional prefix, default BUY)
{% endcomment %}
{% liquid
  assign card_product = product
  assign btn_prefix = button_label | default: 'BUY' | strip
  if btn_prefix == blank
    assign btn_prefix = 'BUY'
  endif

  assign card_default_asset = ''
  case card_product.handle
    when 'hair-regrowth-spray'
      assign card_default_asset = 'home-card-hair-regrowth-spray.jpg'
    when 'anti-frizz-keratin-serum'
      assign card_default_asset = 'home-card-anti-frizz-keratin-serum.jpg'
    when 'floral-blossom-hair-mist'
      assign card_default_asset = 'home-card-floral-blossom-hair-mist.jpg'
    when 'hair-care-bundle'
      assign card_default_asset = 'feature-bundle.jpeg'
  endcase

  assign card_bg_url = ''
  if card_product.featured_image != blank
    assign card_bg_url = card_product.featured_image | image_url: width: 800
  elsif card_default_asset != blank
    assign card_bg_url = card_default_asset | asset_url
  endif

  assign card_title = card_product.title | upcase
%}

{% if card_product.handle == 'hair-care-bundle' %}
  {% assign card_btn_text = 'VIEW BUNDLE' %}
{% else %}
  {% capture card_btn_text %}{{ btn_prefix }} - {{ card_product.price | money }}{% endcapture %}
{% endif %}

<div class="card" data-card-url="{{ card_product.url }}">
  <div
    class="card-image"
    {% if card_bg_url != blank %}
      style="background-image: url('{{ card_bg_url }}');"
    {% endif %}
    role="img"
    aria-label="{{ card_product.title | escape }}"
  ></div>
  <div class="card-info">
    <h3>{{ card_title }}</h3>
    <a class="card-btn" href="{{ card_product.url }}">{{ card_btn_text }}</a>
  </div>
</div>
