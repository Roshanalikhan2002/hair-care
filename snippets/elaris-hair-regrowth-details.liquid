{% comment %} Hair Regrowth Spray — product details (collections band) {% endcomment %}
<div class="elaris-product-details">
  <div class="elaris-product-details__hero">
    <p class="elaris-product-details__kicker">Grow Stronger. Feel Fuller.</p>
    <h3 class="elaris-product-details__title">Stronger Hair Starts at the Root</h3>
    <p class="elaris-product-details__lead">A daily scalp spray for <strong>stronger roots</strong> + <strong>healthier, denser hair</strong>.</p>
