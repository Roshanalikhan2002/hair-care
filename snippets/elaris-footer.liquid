{% liquid
  assign instagram_url = settings.social_instagram_link
  if instagram_url == blank
    assign instagram_url = 'https://www.instagram.com/e7haircare0.01?igsh=enQ4MWhyOXI2ZXZn'
  endif
%}
<footer class="site-footer">
  <div class="footer-top">
    <div class="footer-column">
      <details class="footer-accordion">
        <summary class="footer-title">
          Policies <span class="icon">+</span>
        </summary>
        <ul class="footer-links">
          {% if pages['privacy-policy'] %}
            <li><a href="{{ pages['privacy-policy'].url }}">Privacy Policy</a></li>
          {% elsif shop.privacy_policy %}
            <li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
          {% else %}
            <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
          {% endif %}
          {% if shop.refund_policy %}
            <li><a href="{{ shop.refund_policy.url }}">Refund Policy</a></li>
          {% else %}
            <li><a href="#">Refund Policy</a></li>
          {% endif %}
          {% if shop.terms_of_service %}
            <li><a href="{{ shop.terms_of_service.url }}">Terms of Service</a></li>
          {% else %}
            <li><a href="#">Terms of Service</a></li>
          {% endif %}
          {% if shop.shipping_policy %}
            <li><a href="{{ shop.shipping_policy.url }}">Shipping Policy</a></li>
          {% else %}
            <li><a href="#">Shipping Policy</a></li>
          {% endif %}
          <li><a href="#">Cookies Policy</a></li>
          <li><a href="#">FAQ</a></li>
          <li>
            <a href="{% if pages['about-us'] %}{{ pages['about-us'].url }}{% elsif pages.about %}{{ pages.about.url }}{% else %}/pages/about-us{% endif %}">About Us</a>
          </li>
          <li>
            <a href="{% if pages.contact %}{{ pages.contact.url }}{% else %}#{% endif %}">Contact Us</a>
          </li>
        </ul>
      </details>
    </div>

    <div class="footer-column">
      <details class="footer-accordion">
        <summary class="footer-title">
          Sign-up <span class="icon">+</span>
        </summary>
        <div class="footer-signup">
          <p>
            Enter your email below to be the first to know about new product launches, exclusive offers, and more!
          </p>
          {% form 'customer', class: 'footer-newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="email-form">
              <input type="email" name="contact[email]" placeholder="Enter your email" required value="">
              <button type="submit" aria-label="Subscribe">&#8594;</button>
            </div>
          {% endform %}
          <p class="disclaimer">
            By subscribing you agree to the
            {% if shop.terms_of_service %}
              <a href="{{ shop.terms_of_service.url }}">Terms of Use</a>
            {% else %}
              <a href="#">Terms of Use</a>
            {% endif %}
            &amp;
            {% if shop.privacy_policy %}
              <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
            {% else %}
              <a href="#">Privacy Policy</a>
            {% endif %}
            .
          </p>
        </div>
      </details>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="social-icons">
      <a href="{{ instagram_url }}" rel="noopener noreferrer" target="_blank" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
    </div>
    <div class="copyright">
      <p>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}.</p>
      <p>Site by iBeAuthentic LLC</p>
    </div>
  </div>
</footer>
