<footer class="site-footer">
  <div class="footer-top">
    <div class="footer-column">
      <details class="footer-accordion">
        <summary class="footer-title">
          Shop <span class="icon">+</span>
        </summary>
        <ul class="footer-links">
          <li><a href="{{ routes.all_products_collection_url }}">Best Sellers</a></li>
          <li><a href="{{ routes.collections_url }}">Promotions</a></li>
          <li><a href="{{ routes.collections_url }}">Kits &amp; Bundles</a></li>
          <li><a href="{{ routes.all_products_collection_url }}">Shop All</a></li>
          <li>
            <a href="{% if pages['salon-locator'] %}{{ pages['salon-locator'].url }}{% else %}#{% endif %}">Salon Locator</a>
          </li>
        </ul>
      </details>
    </div>

    <div class="footer-column">
      <details class="footer-accordion">
        <summary class="footer-title">
          Policies <span class="icon">+</span>
        </summary>
        <ul class="footer-links">
          {% if shop.privacy_policy %}
            <li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
          {% else %}
            <li><a href="#">Privacy Policy</a></li>
          {% endif %}
          {% if shop.refund_policy %}
            <li><a href="{{ shop.refund_policy.url }}">Refund Policy</a></li>
          {% else %}
            <li><a href="#">Refund Policy</a></li>
          {% endif %}
          {% if shop.terms_of_service %}
            <li><a href="{{ shop.terms_of_service.url }}">Terms of Service</a></li>
          {% else %}
            <li><a href="#">Terms of Service</a></li>
          {% endif %}
          {% if shop.shipping_policy %}
            <li><a href="{{ shop.shipping_policy.url }}">Shipping Policy</a></li>
          {% else %}
            <li><a href="#">Shipping Policy</a></li>
          {% endif %}
          <li><a href="#">Cookies Policy</a></li>
          <li><a href="#">FAQ</a></li>
          <li>
            <a href="{% if pages.contact %}{{ pages.contact.url }}{% else %}#{% endif %}">Contact Us</a>
          </li>
        </ul>
      </details>
    </div>

    <div class="footer-column">
      <details class="footer-accordion">
        <summary class="footer-title">
          Sign-up <span class="icon">+</span>
        </summary>
        <div class="footer-signup">
          <p>
            Enter your email below to be the first to know about new product launches, exclusive offers, and more!
          </p>
          {% form 'customer', class: 'footer-newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="email-form">
              <input type="email" name="contact[email]" placeholder="Enter your email" required value="">
              <button type="submit" aria-label="Subscribe">&#8594;</button>
            </div>
          {% endform %}
          <p class="disclaimer">
            By subscribing you agree to the
            {% if shop.terms_of_service %}
              <a href="{{ shop.terms_of_service.url }}">Terms of Use</a>
            {% else %}
              <a href="#">Terms of Use</a>
            {% endif %}
            &amp;
            {% if shop.privacy_policy %}
              <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
            {% else %}
              <a href="#">Privacy Policy</a>
            {% endif %}
            .
          </p>
        </div>
      </details>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="social-icons">
      <a href="{{ settings.social_facebook_link | default: '#' }}" rel="noopener" target="_blank" aria-label="Facebook">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
        </svg>
      </a>
      <a href="{{ settings.social_instagram_link | default: '#' }}" rel="noopener" target="_blank" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
      <a href="{{ settings.social_youtube_link | default: '#' }}" rel="noopener" target="_blank" aria-label="YouTube">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path>
          <polygon fill="#fff" points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
        </svg>
      </a>
    </div>
    <div class="copyright">
      <p>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}.</p>
      <p>Site by iBeAuthentic LLC</p>
    </div>
  </div>
</footer>
