{% liquid
  assign ann = settings.elaris_announcement_text | default: 'buy 1 get 1 free' | strip
  assign ann_d = ann | downcase
  if ann_d contains 'free shipping' or ann_d contains 'smoothing solution' or ann_d contains 'orders $'
    assign ann = 'buy 1 get 1 free'
  endif
%}
<div class="elaris-announcement" role="region" aria-label="Announcement">
  <div class="elaris-announcement__strip">
    {%- assign ann_label = '• ' | append: ann | append: ' •' -%}
    {%- for i in (1..3) -%}
      <span class="elaris-announcement__cell" {% if i > 1 %}aria-hidden="true"{% endif %}>{{ ann_label }}</span>
    {%- endfor -%}
  </div>
</div>
<style>
  .elaris-announcement {
    background: #580514;
    color: #fff;
    padding: 10px 12px;
    font-size: 14px;
    font-weight: 600;
    overflow: hidden;
    font-family: Arial, Helvetica, sans-serif;
  }
  .elaris-announcement__strip {
    display: flex;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .elaris-announcement__cell {
    flex: 1 1 0;
    min-width: 0;
    text-align: center;
    white-space: nowrap;
  }
  @media (max-width: 560px) {
    .elaris-announcement {
      font-size: 12px;
      padding-left: 8px;
      padding-right: 8px;
    }
    .elaris-announcement__strip {
      gap: 4px;
    }
  }
</style>
