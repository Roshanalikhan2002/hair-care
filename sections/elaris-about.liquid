{% liquid
  assign page_heading = section.settings.heading | strip
  if page_heading == blank
    if page.title != blank
      assign page_heading = page.title
    else
      assign page_heading = 'About Us'
    endif
  endif
%}

<div class="elaris-about-root elaris-home-root">
  {% render 'elaris-navbar', section: section %}

  <main class="elaris-about-main">
    <header class="elaris-about-hero">
      <h1>{{ page_heading }}</h1>
    </header>

    <div class="elaris-about-content">
      {% if section.settings.paragraph_1 != blank %}
        <p>{% render 'elaris-brandize', text: section.settings.paragraph_1 %}</p>
      {% endif %}
      {% if section.settings.paragraph_2 != blank %}
        <p>{% render 'elaris-brandize', text: section.settings.paragraph_2 %}</p>
      {% endif %}
      {% if section.settings.paragraph_3 != blank %}
        <p>{% render 'elaris-brandize', text: section.settings.paragraph_3 %}</p>
      {% endif %}
      {% if section.settings.paragraph_4 != blank %}
        <p>{% render 'elaris-brandize', text: section.settings.paragraph_4 %}</p>
      {% endif %}
      {% if section.settings.paragraph_5 != blank %}
        <p>{% render 'elaris-brandize', text: section.settings.paragraph_5 %}</p>
      {% endif %}
    </div>
  </main>

  {% render 'elaris-footer' %}
</div>

{% schema %}
{
  "name": "ELARÉ about",
  "tag": "section",
  "class": "elaris-about-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "ELARÉ"
    },
    {
      "type": "header",
      "content": "Navigation URLs"
    },
    {
      "type": "url",
      "id": "nav_shop_url",
      "label": "Shop link"
    },
    {
      "type": "url",
      "id": "nav_offers_url",
      "label": "Offers link"
    },
    {
      "type": "url",
      "id": "nav_learn_url",
      "label": "Learn link"
    },
    {
      "type": "url",
      "id": "nav_quiz_url",
      "label": "Hair Quiz link"
    },
    {
      "type": "url",
      "id": "nav_pros_url",
      "label": "Pros link"
    },
    {
      "type": "header",
      "content": "Page content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave empty to use the page title from Shopify.",
      "default": "About Us"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "At ELARÉ, we believe beauty is a journey of care, confidence, and conscious choices, blending Sunnah wisdom with modern skincare. We see beauty not as a fleeting trend but as a practice of respect for oneself. Every formula we create, whether for skin or hair, is guided by a single principle: effectiveness without compromise. We combine the purity of Sunnah-blessed ingredients with modern, science-backed formulations, giving you products that are both ethical and extraordinary."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Our offerings span skincare essentials that cleanse, nourish, repair, and brighten, as well as haircare solutions that strengthen, revive, and support natural vitality. Each ingredient is carefully sourced, clinically validated, and infused with the intention of delivering real results, without unnecessary additives, harsh chemicals, or inflated costs."
    },
    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragraph 3",
      "default": "We believe that access to rare, potent ingredients should not be limited to the global luxury market. ELARÉ bridges this gap, bringing high-efficacy formulations directly to your daily routine. From nourishing creams and serums that restore clarity and radiance, to hair sprays and mists that strengthen roots and refresh strands, our products are designed to support a holistic journey of self-care."
    },
    {
      "type": "textarea",
      "id": "paragraph_4",
      "label": "Paragraph 4",
      "default": "Beyond the formulations, our brand stands for integrity and mindfulness. Every bottle reflects our commitment to conscious choices, ethical sourcing, and sustainability. Skincare and haircare are not vanity, they are rituals that cultivate confidence, restore balance, and foster a sense of calm and empowerment in everyday life."
    },
    {
      "type": "textarea",
      "id": "paragraph_5",
      "label": "Paragraph 5",
      "default": "At ELARÉ, we invite you to experience beauty as it was meant to be: intentional, effective, and transformative. Step into a world where each product is a reflection of care, science, and tradition, thoughtfully created to support your natural glow and healthy hair."
    }
  ],
  "presets": [
    {
      "name": "ELARÉ about"
    }
  ]
}
{% endschema %}
