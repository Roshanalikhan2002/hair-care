{{ 'elaris-home.css' | asset_url | stylesheet_tag }}
{{ 'elaris-footer.css' | asset_url | stylesheet_tag }}

{% liquid
  assign hero_heading = section.settings.hero_heading | strip
  assign hero_subheading = section.settings.hero_subheading | strip
  assign hero_cta = section.settings.hero_cta_label | strip
  assign hero_h_down = hero_heading | downcase
  assign hero_s_down = hero_subheading | downcase
  assign hero_c_down = hero_cta | downcase
  if hero_h_down contains 'mother' or hero_h_down contains 'free gifts for the women'
    assign hero_heading = ''
  endif
  if hero_s_down contains 'mother' or hero_s_down contains 'body crème' or hero_s_down contains 'scalp reboot' or hero_s_down contains 'curated care'
    assign hero_subheading = ''
  endif
  if hero_c_down contains 'mother' or hero_c_down contains "mother's day"
    assign hero_cta = ''
  endif
%}

<div class="elaris-home-root">
  {% render 'elaris-navbar', section: section %}

  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <picture>
        {% if section.settings.hero_mobile_image != blank %}
          <source media="(max-width: 1024px)" srcset="{{ section.settings.hero_mobile_image | image_url: width: 1600 }}">
        {% else %}
          <source media="(max-width: 1024px)" srcset="{{ 'hero-mobile.jpeg' | asset_url }}">
        {% endif %}
        {% if section.settings.hero_desktop_image != blank %}
          <img
            class="hero-banner-img"
            src="{{ section.settings.hero_desktop_image | image_url: width: 2400 }}"
            alt=""
            width="3840"
            height="2160"
            loading="eager"
            decoding="async"
          >
        {% else %}
          <img
            class="hero-banner-img"
            src="{{ 'hero-desktop.jpeg' | asset_url }}"
            alt=""
            width="3840"
            height="2160"
            loading="eager"
            decoding="async"
          >
        {% endif %}
      </picture>
    </div>

    {% liquid
      assign show_hero_copy = false
      if hero_heading != blank or hero_subheading != blank or hero_cta != blank
        assign show_hero_copy = true
      endif
    %}
    {% if show_hero_copy %}
      <div class="hero-left">
        <div class="hero-copy">
          {% if hero_heading != blank %}
            <h1>{{ hero_heading }}</h1>
          {% endif %}
          {% if hero_subheading != blank %}
            <p>{{ hero_subheading }}</p>
          {% endif %}
          {% if hero_cta != blank %}
            <a href="{{ section.settings.hero_cta_link | default: '#' }}">{{ hero_cta }}</a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </section>

  {% assign card_blocks_count = 0 %}
  {% for block in section.blocks %}
    {% if block.type == 'card' %}
      {% assign card_blocks_count = card_blocks_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  <section class="product-cards">
    {% for block in section.blocks %}
      {% if block.type == 'card' %}
        {% assign block_card_url = '' %}
        {% if block.settings.product != blank %}
          {% assign block_card_url = block.settings.product.url %}
        {% elsif block.settings.link != blank %}
          {% assign block_card_url = block.settings.link %}
        {% endif %}
        {% assign card_default_asset = '' %}
        {% if block.settings.product != blank %}
          {% case block.settings.product.handle %}
            {% when 'hair-regrowth-spray' %}
              {% assign card_default_asset = 'home-card-hair-regrowth-spray.jpg' %}
            {% when 'anti-frizz-keratin-serum' %}
              {% assign card_default_asset = 'home-card-anti-frizz-keratin-serum.jpg' %}
            {% when 'floral-blossom-hair-mist' %}
              {% assign card_default_asset = 'home-card-floral-blossom-hair-mist.jpg' %}
            {% when 'hair-care-bundle' %}
              {% assign card_default_asset = 'feature-bundle.jpeg' %}
          {% endcase %}
        {% endif %}
        {% if card_default_asset == blank %}
          {% assign link_h = block.settings.link | default: '' | downcase %}
          {% assign title_h = block.settings.title | default: '' | downcase %}
          {% if link_h contains 'hair-regrowth-spray' or title_h contains 'regrow' %}
            {% assign card_default_asset = 'home-card-hair-regrowth-spray.jpg' %}
          {% elsif link_h contains 'anti-frizz' or title_h contains 'keratin' or title_h contains 'frizz' %}
            {% assign card_default_asset = 'home-card-anti-frizz-keratin-serum.jpg' %}
          {% elsif link_h contains 'floral-blossom' or title_h contains 'floral' or title_h contains 'blossom' %}
            {% assign card_default_asset = 'home-card-floral-blossom-hair-mist.jpg' %}
          {% elsif link_h contains 'hair-care-bundle' or title_h contains 'bundle' %}
            {% assign card_default_asset = 'feature-bundle.jpeg' %}
          {% endif %}
        {% endif %}
        {% assign card_link_raw = block.settings.link | default: '' %}
        {% assign card_handle_from_link = '' %}
        {% if card_link_raw contains '/products/' %}
          {% assign card_handle_from_link = card_link_raw | split: '/products/' | last | split: '?' | first | split: '/' | first %}
        {% endif %}
        {% assign card_link_product = all_products[card_handle_from_link] %}
        {% assign card_bg_url = '' %}
        {% if block.settings.image != blank %}
          {% assign card_bg_url = block.settings.image | image_url: width: 1200 %}
        {% elsif card_default_asset != blank %}
          {% assign card_bg_url = card_default_asset | asset_url %}
        {% elsif card_link_product != blank and card_link_product.featured_image != blank %}
          {% assign card_bg_url = card_link_product.featured_image | image_url: width: 1200 %}
        {% endif %}
        <div class="card"{% if block_card_url != blank %} data-card-url="{{ block_card_url }}"{% endif %} {{ block.shopify_attributes }}>
          <div
            class="card-image"
            {% if card_bg_url != blank %}
              style="background-image: url('{{ card_bg_url }}');"
            {% endif %}
            role="img"
            aria-label="{{ block.settings.title | escape }}"
          ></div>
          <div class="card-info">
            <h3>{{ block.settings.title }}</h3>
            {% if block.settings.product != blank %}
              {% assign card_product = block.settings.product %}
              <a class="card-btn" href="{{ card_product.url }}">
                {{- block.settings.button_label | default: 'BUY' }} - {{ card_product.price | money -}}
              </a>
            {% elsif block.settings.link != blank %}
              <a class="card-btn" href="{{ block.settings.link }}">{{ block.settings.button_label }}</a>
            {% else %}
              <button type="button" class="card-btn">{{ block.settings.button_label }}</button>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {% if card_blocks_count == 0 %}
      {% assign fallback_handles = 'hair-regrowth-spray,anti-frizz-keratin-serum,floral-blossom-hair-mist' | split: ',' %}
      {% for fallback_handle in fallback_handles %}
        {% assign fallback_product = all_products[fallback_handle] %}
        {% assign card_default_asset = '' %}
        {% case fallback_handle %}
          {% when 'hair-regrowth-spray' %}
            {% assign card_default_asset = 'home-card-hair-regrowth-spray.jpg' %}
          {% when 'anti-frizz-keratin-serum' %}
            {% assign card_default_asset = 'home-card-anti-frizz-keratin-serum.jpg' %}
          {% when 'floral-blossom-hair-mist' %}
            {% assign card_default_asset = 'home-card-floral-blossom-hair-mist.jpg' %}
        {% endcase %}
        <div class="card" data-card-url="/products/{{ fallback_handle }}">
          {% assign fb_bg = card_default_asset | asset_url %}
          <div
            class="card-image"
            style="background-image: url('{{ fb_bg }}');"
            role="img"
            aria-label="{{ fallback_handle | replace: '-', ' ' | escape }}"
          ></div>
          <div class="card-info">
            <h3>
              {% if fallback_product != blank %}
                {{ fallback_product.title }}
              {% else %}
                {{ fallback_handle | replace: '-', ' ' | upcase }}
              {% endif %}
            </h3>
            {% if fallback_product != blank %}
              <a class="card-btn" href="{{ fallback_product.url }}">BUY - {{ fallback_product.price | money }}</a>
            {% else %}
              <a class="card-btn" href="/products/{{ fallback_handle }}">BUY - RS. 0</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </section>

  <section class="product-feature">
    <div
      class="feature-image"
      {% if section.settings.feature_image != blank %}
        style="background-image: url('{{ section.settings.feature_image | image_url: width: 1200 }}');"
      {% else %}
        style="background-image: url('{{ 'feature-bundle.jpeg' | asset_url }}');"
      {% endif %}
    ></div>
    <div class="feature-content">
      <div class="badge">{{ section.settings.feature_badge }}</div>
      <h2>{{ section.settings.feature_heading }}</h2>
      <p>{{ section.settings.feature_text }}</p>
      {% if section.settings.feature_cta_label != blank %}
        {% liquid
          assign feature_cta_href = section.settings.feature_cta_link | strip
          if feature_cta_href == blank
            assign feature_cta_href = '/products/hair-care-bundle'
          endif
        %}
        <a href="{{ feature_cta_href }}" class="btn-black">{{ section.settings.feature_cta_label }}</a>
      {% endif %}
    </div>
  </section>

  {% liquid
    assign faq_blocks_count = 0
    for block in section.blocks
      if block.type == 'faq_item'
        assign faq_blocks_count = faq_blocks_count | plus: 1
      endif
    endfor
  %}
  <section class="faq-section">
    <div class="faq-content">
      <h2>{{ section.settings.faq_heading }}</h2>
      <div class="accordion">
        {% if faq_blocks_count > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'faq_item' %}
              <details class="accordion-item" name="faq-home-{{ section.id }}" {{ block.shopify_attributes }}>
                <summary class="accordion-header">
                  {{ block.settings.question }}
                  <span class="icon">+</span>
                </summary>
                <div class="accordion-body">{{ block.settings.answer }}</div>
              </details>
            {% endif %}
          {% endfor %}
        {% else %}
          {% render 'elaris-home-faq-fallback', home_section_id: section.id %}
        {% endif %}
      </div>
    </div>
    <div
      class="faq-image"
      {% if section.settings.faq_image != blank %}
        style="background-image: url('{{ section.settings.faq_image | image_url: width: 1200 }}');"
      {% else %}
        style="background-image: url('{{ 'faq-image-100.jpg' | asset_url }}');"
      {% endif %}
    ></div>
  </section>

  {% render 'elaris-footer' %}
</div>

<script>
  (function () {
    if (window.innerWidth > 1024) {
      document.querySelectorAll('.elaris-home-root .footer-accordion').forEach(function (el) {
        el.setAttribute('open', '');
      });
    }

    document.querySelectorAll('.elaris-home-root .card[data-card-url]').forEach(function (card) {
      card.addEventListener('click', function (event) {
        if (event.target.closest('a')) return;
        var to = card.getAttribute('data-card-url');
        if (to) window.location.href = to;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "ELARÉHAIR home",
  "tag": "section",
  "class": "elaris-home-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "ELARÉHAIR"
    },
    {
      "type": "header",
      "content": "Navigation URLs"
    },
    {
      "type": "url",
      "id": "nav_shop_url",
      "label": "Shop link"
    },
    {
      "type": "url",
      "id": "nav_offers_url",
      "label": "Offers link"
    },
    {
      "type": "url",
      "id": "nav_learn_url",
      "label": "Learn link"
    },
    {
      "type": "url",
      "id": "nav_quiz_url",
      "label": "Hair Quiz link"
    },
    {
      "type": "url",
      "id": "nav_pros_url",
      "label": "Pros link"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_desktop_image",
      "label": "Hero background (desktop)"
    },
    {
      "type": "image_picker",
      "id": "hero_mobile_image",
      "label": "Hero image (mobile top)"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "hero_subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "text",
      "id": "hero_cta_label",
      "label": "Button label",
      "default": ""
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Featured row"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature image"
    },
    {
      "type": "text",
      "id": "feature_badge",
      "label": "Badge",
      "default": "NEW!"
    },
    {
      "type": "text",
      "id": "feature_heading",
      "label": "Heading",
      "default": "ELARÉ Hair Care Set"
    },
    {
      "type": "textarea",
      "id": "feature_text",
      "label": "Text",
      "default": "Transform your hair routine with the ELARÉ Hair Care Set. This three-product collection is designed to control frizz, strengthen roots, and leave your hair feeling soft, shiny, and beautifully scented. Each product works on its own or together, making styling, protection, and daily care effortless—perfect for home or on-the-go use."
    },
    {
      "type": "text",
      "id": "feature_cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "feature_cta_link",
      "label": "Button link",
      "info": "Leave empty to open Hair Care Bundle (/products/hair-care-bundle). In Theme customize you can set another product URL if your handle differs."
    },
    {
      "type": "header",
      "content": "FAQ"
    },
    {
      "type": "text",
      "id": "faq_heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "image_picker",
      "id": "faq_image",
      "label": "FAQ image"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Product card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "HAIR REGROW SPRAY"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label prefix",
          "default": "BUY"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product (uses live price)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Manual link (if no product)"
        }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Can I use these products every day?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Yes. Floral Blossom Hair Mist is safe for daily use (even several times a day). Hair Regrowth Spray is designed for daily use, morning and night. Anti-Frizz Keratin Serum can be used daily or whenever your hair needs smoothness and control."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ELARÉHAIR home",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "HAIR REGROW SPRAY",
            "button_label": "BUY - RS. 2,790"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "ANTI FRIZZ KERATIN SERUM",
            "button_label": "BUY - RS. 2,680"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "FLORAL BLOSSOM HAIR MIST",
            "button_label": "BUY - RS. 2,960"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I use these products every day?",
            "answer": "Yes. Floral Blossom Hair Mist is safe for daily use (even several times a day). Hair Regrowth Spray is designed for daily use, morning and night. Anti-Frizz Keratin Serum can be used daily or whenever your hair needs smoothness and control."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Will they leave my hair or scalp sticky or greasy?",
            "answer": "No. The hair mist is made to feel fresh without stickiness. The keratin serum is non-greasy and does not weigh hair down. The regrowth spray absorbs quickly and is not meant to leave the scalp feeling greasy."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How do damp hair, dry hair, and heat styling work with these products?",
            "answer": "The hair mist works best on dry hair for instant freshness and a long-lasting floral scent. The keratin serum works on both damp and dry hair and helps protect against heat from styling tools. The regrowth spray should stay on the scalp—overnight wear is ideal."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do I need to rinse anything out?",
            "answer": "Leave the regrowth spray on the scalp (no rinse; overnight works best). The mist and serum are leave-in style—apply and style as usual."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are ELARÉ hair products suitable for all hair types?",
            "answer": "Yes. They suit different textures and needs—from frizz control and shine to support for thinning or weaker hair. Each product page has tailored FAQs if you want more detail."
          }
        }
      ]
    }
  ]
}
{% endschema %}
