{{ 'elaris-product.css' | asset_url | stylesheet_tag }}
{{ 'elaris-footer.css' | asset_url | stylesheet_tag }}
{% comment %}B1G1 build: free gift + no subscribe when elaris_b1g1 true. Sync this file from GitHub if store shows old UI.{% endcomment %}

{% assign elaris_form_id = 'ElarisProductForm-' | append: section.id %}

{% if product == blank %}
  <div class="elaris-product-page" style="padding: 40px 20px; text-align: center;">
    <p>This template is for product pages. Assign the “elaris” product template to a product in the admin.</p>
  </div>
{% else %}
  {% assign elaris_regrowth_gallery = false %}
  {% assign elaris_keratin_gallery = false %}
  {% assign elaris_floral_gallery = false %}
  {% assign elaris_asset_gallery = false %}
  {% assign elaris_gallery_src_1 = '' %}
  {% assign elaris_gallery_src_2 = '' %}
  {% if product.handle == 'hair-regrowth-spray' or template.suffix == 'hair-regrowth-spray' %}
    {% assign elaris_regrowth_gallery = true %}
    {% assign elaris_asset_gallery = true %}
    {% assign elaris_gallery_src_1 = 'hair-regrowth-spray.jpg' | asset_url %}
    {% assign elaris_gallery_src_2 = 'hair-regrowth-spray-before-after.jpg' | asset_url %}
  {% elsif product.handle == 'anti-frizz-keratin-serum' or template.suffix == 'anti-frizz-keratin-serum' %}
    {% assign elaris_keratin_gallery = true %}
    {% assign elaris_asset_gallery = true %}
    {% assign elaris_gallery_src_1 = 'anti-frizz-keratin-serum.jpg' | asset_url %}
    {% assign elaris_gallery_src_2 = 'anti-frizz-keratin-serum-before-after.jpg' | asset_url %}
  {% elsif product.handle == 'floral-blossom-hair-mist' or template.suffix == 'floral-blossom-hair-mist' %}
    {% assign elaris_floral_gallery = true %}
    {% assign elaris_asset_gallery = true %}
    {% assign elaris_gallery_src_1 = 'floral-blossom-hair-mist.jpg' | asset_url %}
    {% assign elaris_gallery_src_2 = 'floral-blossom-hair-mist-before-after.jpg' | asset_url %}
  {% endif %}
  {% liquid
    assign elaris_b1g1 = false
    assign ph = product.title | handleize
    assign tit = product.title | strip | downcase
    assign elaris_tag_b1g1 = false
    for t in product.tags
      assign td = t | strip | downcase
      if td == 'b1g1' or td == 'e7-b1g1' or td == 'buy-1-get-1'
        assign elaris_tag_b1g1 = true
      endif
    endfor
    if elaris_tag_b1g1
      assign elaris_b1g1 = true
    endif
    if elaris_b1g1 == false and section.settings.b1g1_enable == true
      assign elaris_b1g1 = true
    endif
    if elaris_b1g1 == false
      if product.handle == 'hair-regrowth-spray' or template.suffix == 'hair-regrowth-spray'
        assign elaris_b1g1 = true
      elsif product.handle == 'anti-frizz-keratin-serum' or template.suffix == 'anti-frizz-keratin-serum'
        assign elaris_b1g1 = true
      elsif product.handle == 'floral-blossom-hair-mist' or template.suffix == 'floral-blossom-hair-mist'
        assign elaris_b1g1 = true
      elsif elaris_regrowth_gallery or elaris_keratin_gallery or elaris_floral_gallery
        assign elaris_b1g1 = true
      elsif ph == 'hair-regrowth-spray' or ph == 'anti-frizz-keratin-serum' or ph == 'floral-blossom-hair-mist'
        assign elaris_b1g1 = true
      elsif tit contains 'floral blossom' and tit contains 'mist'
        assign elaris_b1g1 = true
      elsif tit contains 'anti frizz' and tit contains 'keratin'
        assign elaris_b1g1 = true
      elsif tit contains 'anti-frizz' and tit contains 'keratin'
        assign elaris_b1g1 = true
      elsif tit contains 'hair regrowth' and tit contains 'spray'
        assign elaris_b1g1 = true
      endif
    endif
  %}
  {% liquid
    assign gh_floral = section.settings.b1g1_gift_handle_floral | strip
    if gh_floral == blank
      assign gh_floral = 'floral-blossom-hair-mist'
    endif
    assign gh_regrowth = section.settings.b1g1_gift_handle_regrowth | strip
    if gh_regrowth == blank
      assign gh_regrowth = 'hair-regrowth-spray'
    endif
    assign gh_keratin = section.settings.b1g1_gift_handle_keratin | strip
    if gh_keratin == blank
      assign gh_keratin = 'anti-frizz-keratin-serum'
    endif
  %}
  {% assign gift_floral = all_products[gh_floral] %}
  {% assign gift_regrowth = all_products[gh_regrowth] %}
  {% assign gift_keratin = all_products[gh_keratin] %}
  {% liquid
    assign gift_default_variant_id = ''
    if gift_floral != blank and gift_floral.selected_or_first_available_variant.available
      assign gift_default_variant_id = gift_floral.selected_or_first_available_variant.id
    elsif gift_regrowth != blank and gift_regrowth.selected_or_first_available_variant.available
      assign gift_default_variant_id = gift_regrowth.selected_or_first_available_variant.id
    elsif gift_keratin != blank and gift_keratin.selected_or_first_available_variant.available
      assign gift_default_variant_id = gift_keratin.selected_or_first_available_variant.id
    endif
  %}
  {% assign current_variant = product.selected_or_first_available_variant %}
  {% if current_variant.featured_media %}
    {% assign featured = current_variant.featured_media %}
  {% else %}
    {% assign featured = product.featured_media %}
  {% endif %}
  {% assign first_selling_plan = product.selling_plan_groups.first.selling_plans.first %}

  <div class="elaris-product-page" style="color:#580514;font-family:Arial,Helvetica,sans-serif;">
    {% render 'elaris-navbar', section: section %}

    <div class="promo-strip">
      {% for i in (1..4) %}
        <span>{{ section.settings.promo_strip_text }}</span>
      {% endfor %}
    </div>

    <section class="product-wrap">
      <div class="product-media">
        {% if elaris_asset_gallery %}
          <div class="elaris-regrowth-media">
            <div class="main-image-wrap">
              <div
                class="main-image-placeholder has-image elaris-regrowth-main"
                id="ElarisMainImage-{{ section.id }}"
                data-placeholder-label="{{ 'Main product image' | escape }}"
              >
                <img
                  id="ElarisMainImgTag-{{ section.id }}"
                  src="{{ elaris_gallery_src_1 }}"
                  alt="{{ product.title | escape }}"
                  loading="eager"
                  width="1200"
                  height="1200"
                >
              </div>
            </div>
            <div class="elaris-regrowth-carousel">
              <button
                type="button"
                class="elaris-regrowth-carousel__arrow elaris-regrowth-carousel__arrow--prev"
                id="ElarisRegrowthPrev-{{ section.id }}"
                aria-label="Previous thumbnails"
              >
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M14 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </button>
              <div class="elaris-regrowth-carousel__strip" id="ElarisRegrowthStrip-{{ section.id }}">
                <div id="ElarisThumbs-{{ section.id }}" class="elaris-regrowth-thumb-row">
                  <button
                    type="button"
                    class="thumb elaris-regrowth-thumb is-active"
                    data-image-src="{{ elaris_gallery_src_1 }}"
                    data-image-alt="{{ product.title | escape }}"
                    aria-label="Show product image 1"
                  >
                    <span class="elaris-regrowth-thumb__inner">
                      <img src="{{ elaris_gallery_src_1 }}" alt="" loading="eager" width="160" height="160">
                    </span>
                  </button>
                  <button
                    type="button"
                    class="thumb elaris-regrowth-thumb"
                    data-image-src="{{ elaris_gallery_src_2 }}"
                    data-image-alt="{{ product.title | escape }} — before and after"
                    aria-label="Show before and after"
                  >
                    <span class="elaris-regrowth-thumb__inner">
                      <img src="{{ elaris_gallery_src_2 }}" alt="" loading="lazy" width="160" height="160">
                    </span>
                  </button>
                </div>
              </div>
              <button
                type="button"
                class="elaris-regrowth-carousel__arrow elaris-regrowth-carousel__arrow--next"
                id="ElarisRegrowthNext-{{ section.id }}"
                aria-label="Next thumbnails"
              >
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M10 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              </button>
            </div>
          </div>
        {% else %}
          <div class="main-image-wrap">
            <div
              class="main-image-placeholder{% if featured != blank %} has-image{% endif %}"
              id="ElarisMainImage-{{ section.id }}"
              data-placeholder-label="{{ 'Main product image' | escape }}"
            >
              {% if featured != blank %}
                <img
                  id="ElarisMainImgTag-{{ section.id }}"
                  src="{{ featured | image_url: width: 1200 }}"
                  alt="{{ featured.alt | escape }}"
                  width="{{ featured.width }}"
                  height="{{ featured.height }}"
                  loading="eager"
                >
              {% else %}
                <span>Main product image</span>
              {% endif %}
            </div>
          </div>
          {% if product.media.size > 1 %}
            <div class="thumb-row" id="ElarisThumbs-{{ section.id }}">
              {% for media in product.media %}
                {% if media.media_type == 'image' %}
                  <button
                    type="button"
                    class="thumb{% if forloop.first %} is-active{% endif %}"
                    data-image-src="{{ media | image_url: width: 1200 }}"
                    data-image-srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 1200 }} 1200w"
                    data-image-alt="{{ media.alt | escape }}"
                    aria-label="Show image {{ forloop.index }}"
                  >
                    <img src="{{ media | image_url: width: 200 }}" alt="" loading="lazy" width="200" height="200">
                  </button>
                {% endif %}
              {% endfor %}
            </div>
          {% elsif featured == blank %}
            <div class="thumb-row">
              {% for i in (1..4) %}
                <div class="thumb">Image {{ i }}</div>
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}
      </div>

      <div class="product-info">
        {% for tag in product.tags %}
          {% assign tag_down = tag | downcase %}
          {% if tag_down == 'new' %}
            <div class="tag">NEW</div>
            {% break %}
          {% endif %}
        {% endfor %}
        {% if section.settings.force_new_badge %}
          <div class="tag">NEW</div>
        {% endif %}

        <h1>{{ product.title }}</h1>
        {% if product.metafields.custom.subtitle != blank %}
          <h3>{% render 'elaris-brandize', text: product.metafields.custom.subtitle %}</h3>
        {% elsif section.settings.subtitle != blank %}
          <h3>{% render 'elaris-brandize', text: section.settings.subtitle %}</h3>
        {% endif %}

        {% liquid
          assign elaris_product_description = product.description
          if section.settings.description_override != blank
            assign elaris_product_description = section.settings.description_override
          elsif elaris_product_description == blank and product.handle == 'hair-regrowth-spray'
            assign elaris_product_description = 'A fast-absorbing scalp spray designed to reduce hair fall and support healthy regrowth without leaving residue. It helps strengthen roots, improve density, and restore hair vitality with consistent use.'
          elsif elaris_product_description == blank and product.handle == 'anti-frizz-keratin-serum'
            assign elaris_product_description = 'A smoothing hair serum designed to control frizz, protect against heat, and restore softness without weighing hair down. It seals moisture, enhances shine, and leaves hair silky, manageable, and smooth with every use.'
          elsif elaris_product_description == blank and product.handle == 'floral-blossom-hair-mist'
            assign elaris_product_description = 'A refreshing hair mist designed to instantly revive your hair with a soft floral scent. It helps add a natural shine, refresh between washes, and keep your hair feeling clean and beautifully scented all day.'
          endif
        %}
        {% if elaris_product_description != blank %}
          <div class="rte product-description">
            {% if elaris_product_description contains '<' %}
              {% render 'elaris-brandize', text: elaris_product_description %}
            {% else %}
              <p>{% render 'elaris-brandize', text: elaris_product_description %}</p>
            {% endif %}
          </div>
        {% endif %}

        {% liquid
          assign elaris_form_class = 'elaris-product-form'
          if elaris_b1g1
            assign elaris_form_class = elaris_form_class | append: ' elaris-product-form--b1g1'
          endif
          assign elaris_b1g1_add_disabled = false
          if elaris_b1g1 and gift_default_variant_id == blank
            assign elaris_b1g1_add_disabled = true
          endif
        %}
        {% form 'product', product, id: elaris_form_id, class: elaris_form_class, novalidate: 'novalidate' %}
          <input type="hidden" name="id" id="ElarisVariantId-{{ section.id }}" value="{{ current_variant.id }}">
          {% unless elaris_b1g1 %}
            <input type="hidden" name="selling_plan" id="ElarisSellingPlan-{{ section.id }}" value="">
          {% endunless %}

          {% unless product.has_only_default_variant %}
            <div class="variant-select" style="margin-bottom:14px;">
              <label for="ElarisVariantSelect-{{ section.id }}" class="label" style="display:block;">Options</label>
              <select
                id="ElarisVariantSelect-{{ section.id }}"
                style="width:100%;padding:10px;font-size:16px;border:1px solid rgba(88,5,20,0.35);border-radius:8px;"
              >
                {% for variant in product.variants %}
                  <option
                    value="{{ variant.id }}"
                    {% if variant == current_variant %}
                      selected
                    {% endif %}
                    {% unless variant.available %}
                      disabled
                    {% endunless %}
                  >
                    {{ variant.title }} — {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endunless %}

          {% if elaris_b1g1 %}
            <input type="hidden" name="quantity" id="ElarisQtyInput-{{ section.id }}" value="1" min="1">
          {% else %}
            <div class="qty-block">
              <div class="label">quantity</div>
              <div class="qty-controls">
                <button type="button" id="ElarisQtyMinus-{{ section.id }}" aria-label="Decrease quantity">-</button>
                <span id="ElarisQtyDisplay-{{ section.id }}">1</span>
                <button type="button" id="ElarisQtyPlus-{{ section.id }}" aria-label="Increase quantity">+</button>
              </div>
              <input type="hidden" name="quantity" id="ElarisQtyInput-{{ section.id }}" value="1" min="1">
            </div>
          {% endif %}

          {% if elaris_b1g1 %}
            <div class="purchase-label">Buy 1 Get 1</div>
            {% if section.settings.b1g1_note != blank %}
              <p class="elaris-b1g1-note">{{ section.settings.b1g1_note }}</p>
            {% endif %}
            <div class="buy-option active elaris-b1g1-pill" aria-current="true">
              <span>{{ section.settings.b1g1_box_label }}</span>
              <span id="ElarisPriceOnetime-{{ section.id }}">{{ current_variant.price | money }}</span>
            </div>

            <fieldset class="elaris-free-gift">
              <legend class="elaris-free-gift__legend">Choose your free gift</legend>
              {% if gift_default_variant_id == blank %}
                <p class="elaris-free-gift__warn">Publish all three gift products with at least one available variant so customers can choose a free gift.</p>
              {% endif %}
              {% if gift_floral != blank %}
                {% assign gv = gift_floral.selected_or_first_available_variant %}
                <label class="elaris-free-gift__row{% unless gv.available %} elaris-free-gift__row--disabled{% endunless %}">
                  <input
                    type="radio"
                    name="elaris_free_gift"
                    value="{{ gv.id }}"
                    {% if gv.id == gift_default_variant_id %}checked{% endif %}
                    {% unless gv.available %}disabled{% endunless %}
                  >
                  <span class="elaris-free-gift__thumb" aria-hidden="true">
                    {% if gv.image %}
                      <img src="{{ gv.image | image_url: width: 160 }}" alt="" width="72" height="72" loading="lazy">
                    {% elsif gift_floral.featured_media %}
                      <img src="{{ gift_floral.featured_media | image_url: width: 160 }}" alt="" width="72" height="72" loading="lazy">
                    {% endif %}
                  </span>
                  <span class="elaris-free-gift__text">{{ gift_floral.title }}</span>
                </label>
              {% endif %}
              {% if gift_regrowth != blank %}
                {% assign gv = gift_regrowth.selected_or_first_available_variant %}
                <label class="elaris-free-gift__row{% unless gv.available %} elaris-free-gift__row--disabled{% endunless %}">
                  <input
                    type="radio"
                    name="elaris_free_gift"
                    value="{{ gv.id }}"
                    {% if gv.id == gift_default_variant_id %}checked{% endif %}
                    {% unless gv.available %}disabled{% endunless %}
                  >
                  <span class="elaris-free-gift__thumb" aria-hidden="true">
                    {% if gv.image %}
                      <img src="{{ gv.image | image_url: width: 160 }}" alt="" width="72" height="72" loading="lazy">
                    {% elsif gift_regrowth.featured_media %}
                      <img src="{{ gift_regrowth.featured_media | image_url: width: 160 }}" alt="" width="72" height="72" loading="lazy">
                    {% endif %}
                  </span>
                  <span class="elaris-free-gift__text">{{ gift_regrowth.title }}</span>
                </label>
              {% endif %}
              {% if gift_keratin != blank %}
                {% assign gv = gift_keratin.selected_or_first_available_variant %}
                <label class="elaris-free-gift__row{% unless gv.available %} elaris-free-gift__row--disabled{% endunless %}">
                  <input
                    type="radio"
                    name="elaris_free_gift"
                    value="{{ gv.id }}"
                    {% if gv.id == gift_default_variant_id %}checked{% endif %}
                    {% unless gv.available %}disabled{% endunless %}
                  >
                  <span class="elaris-free-gift__thumb" aria-hidden="true">
                    {% if gv.image %}
                      <img src="{{ gv.image | image_url: width: 160 }}" alt="" width="72" height="72" loading="lazy">
                    {% elsif gift_keratin.featured_media %}
                      <img src="{{ gift_keratin.featured_media | image_url: width: 160 }}" alt="" width="72" height="72" loading="lazy">
                    {% endif %}
                  </span>
                  <span class="elaris-free-gift__text">{{ gift_keratin.title }}</span>
                </label>
              {% endif %}
            </fieldset>
          {% else %}
            <div class="purchase-label">purchase options</div>

            <button
              type="button"
              class="buy-option active"
              id="ElarisPurchaseOnetime-{{ section.id }}"
              data-mode="onetime"
            >
              <span>one time purchase</span>
              <span id="ElarisPriceOnetime-{{ section.id }}">{{ current_variant.price | money }}</span>
            </button>

            {% if first_selling_plan != nil %}
              <button
                type="button"
                class="buy-option"
                id="ElarisPurchaseSubscribe-{{ section.id }}"
                data-mode="subscribe"
                data-selling-plan-id="{{ first_selling_plan.id }}"
              >
                <span>subscribe and save</span>
                <span>
                  <span id="ElarisPriceSubscribe-{{ section.id }}">{{ section.settings.subscribe_price_placeholder }}</span>
                  <s id="ElarisCompareSubscribe-{{ section.id }}">{{ current_variant.price | money }}</s>
                </span>
              </button>
            {% else %}
              <button type="button" class="buy-option" id="ElarisPurchaseSubscribe-{{ section.id }}" data-mode="subscribe-placeholder">
                <span>subscribe and save</span>
                <span>
                  {% if current_variant.compare_at_price > current_variant.price %}
                    <span id="ElarisPriceSubscribe-{{ section.id }}">{{ current_variant.price | money }}</span>
                    <s id="ElarisCompareSubscribe-{{ section.id }}">{{ current_variant.compare_at_price | money }}</s>
                  {% else %}
                    <span id="ElarisPriceSubscribe-{{ section.id }}">{{ section.settings.subscribe_price_placeholder }}</span>
                    <s id="ElarisCompareSubscribe-{{ section.id }}">{{ current_variant.price | money }}</s>
                  {% endif %}
                </span>
              </button>
            {% endif %}
          {% endif %}

          <button
            type="submit"
            name="add"
            class="add-cart"
            id="ElarisAddCart-{{ section.id }}"
            {% if elaris_b1g1_add_disabled or current_variant.available == false %}
              disabled
            {% endif %}
          >
            {% if current_variant.available %}
              {% if elaris_b1g1 %}
                add to cart — buy 1 get 1
              {% else %}
                add to cart
              {% endif %}
            {% else %}
              sold out
            {% endif %}
          </button>
        {% endform %}
      </div>
    </section>

    <section class="collections-wrap">
      <h2 class="collections-heading">{{ section.settings.collections_heading }}</h2>

      <div
        class="collections-image has-image"
        {% if section.settings.collections_image != blank %}
          style="background-image: url('{{ section.settings.collections_image | image_url: width: 1400 }}');"
        {% elsif elaris_keratin_gallery %}
          style="background-image: url('{{ 'anti-frizz-our-collection.jpg' | asset_url }}');"
        {% elsif elaris_floral_gallery %}
          style="background-image: url('{{ 'floral-blossom-our-collection.jpg' | asset_url }}');"
        {% else %}
          style="background-image: url('{{ 'our-collection.jpg' | asset_url }}');"
        {% endif %}
      ></div>

      <div class="collections-content">
        {% for block in section.blocks %}
          {% if block.type == 'collection_row' %}
            {% liquid
              assign row_link = block.settings.link | strip
              if row_link == blank or row_link == '#'
                assign row_link = ''
              endif
            %}
            <div class="collection-item{% if row_link == blank %} collection-item--toggle{% endif %}" {{ block.shopify_attributes }}>
              <div class="item-main">
                <div class="item-title-row">
                  <span class="item-icon">{{ block.settings.icon }}</span>
                  <h3>{{ block.settings.title }}</h3>
                </div>
                <p>{% render 'elaris-brandize', text: block.settings.text %}</p>
              </div>
              {% if row_link != blank %}
                <a class="item-arrow" href="{{ row_link }}" aria-label="open collection">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5l7 7-7 7"></path></svg>
                </a>
              {% else %}
                <button type="button" class="item-arrow" data-collection-toggle aria-expanded="false" aria-label="Show details">
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5l7 7-7 7"></path></svg>
                </button>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </section>

    <section class="faq-wrap">
      <div class="faq-content">
        <h2>{{ section.settings.faq_heading }}</h2>

        {% for block in section.blocks %}
          {% if block.type == 'faq_item' %}
            <details class="faq-item" {{ block.shopify_attributes }}>
              <summary>
                <span>{{ block.settings.question }}</span>
                <span class="faq-toggle">+</span>
              </summary>
              <p class="answer">{{ block.settings.answer }}</p>
            </details>
          {% endif %}
        {% endfor %}
      </div>

      <div
        class="faq-image{% if section.settings.faq_image != blank or elaris_regrowth_gallery or elaris_keratin_gallery or elaris_floral_gallery %} has-image{% endif %}"
        {% if section.settings.faq_image != blank %}
          style="background-image: url('{{ section.settings.faq_image | image_url: width: 1200 }}');"
        {% elsif elaris_regrowth_gallery %}
          style="background-image: url('{{ 'hair-regrowth-faq.jpg' | asset_url }}');"
        {% elsif elaris_keratin_gallery %}
          style="background-image: url('{{ 'anti-frizz-faq.jpg' | asset_url }}');"
        {% elsif elaris_floral_gallery %}
          style="background-image: url('{{ 'floral-blossom-faq.jpg' | asset_url }}');"
        {% endif %}
      >
        {% if section.settings.faq_image == blank and elaris_regrowth_gallery == false and elaris_keratin_gallery == false and elaris_floral_gallery == false %}
          <span>FAQ image area</span>
        {% endif %}
      </div>
    </section>

    {% render 'elaris-footer' %}
  </div>

  <script type="application/json" id="ElarisProductJson-{{ section.id }}">
    {{ product | json }}
  </script>
  <script>
    (function () {
      var sectionId = '{{ section.id }}';
      var elarisB1g1Page = {% if elaris_b1g1 %}true{% else %}false{% endif %};
      var form = document.getElementById('ElarisProductForm-' + sectionId);
      if (!form) return;

      var productJsonEl = document.getElementById('ElarisProductJson-' + sectionId);
      var productData = productJsonEl ? JSON.parse(productJsonEl.textContent) : null;

      function formatMoney(cents) {
        if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
          return Shopify.formatMoney(cents, {{ shop.money_format | json }});
        }
        return (cents / 100).toFixed(2);
      }

      function variantById(id) {
        if (!productData || !productData.variants) return null;
        var vid = parseInt(id, 10);
        for (var i = 0; i < productData.variants.length; i++) {
          if (productData.variants[i].id === vid) return productData.variants[i];
        }
        return null;
      }

      function syncVariantUi(variant) {
        if (!variant) return;
        var onetime = document.getElementById('ElarisPriceOnetime-' + sectionId);
        var subPrice = document.getElementById('ElarisPriceSubscribe-' + sectionId);
        var subStrike = document.getElementById('ElarisCompareSubscribe-' + sectionId);
        if (onetime) onetime.textContent = formatMoney(variant.price);
        if (subStrike) subStrike.textContent = formatMoney(variant.price);
        var addBtn = document.getElementById('ElarisAddCart-' + sectionId);
        if (addBtn) {
          addBtn.disabled = !variant.available;
          if (variant.available) {
            addBtn.textContent = elarisB1g1Page ? 'add to cart — buy 1 get 1' : 'add to cart';
          } else {
            addBtn.textContent = 'sold out';
          }
        }
      }

      var variantInput = document.getElementById('ElarisVariantId-' + sectionId);
      var variantSelect = document.getElementById('ElarisVariantSelect-' + sectionId);
      var qtyInput = document.getElementById('ElarisQtyInput-' + sectionId);
      var qtyDisplay = document.getElementById('ElarisQtyDisplay-' + sectionId);
      var sellingPlanInput = document.getElementById('ElarisSellingPlan-' + sectionId);
      var btnOnetime = document.getElementById('ElarisPurchaseOnetime-' + sectionId);
      var btnSubscribe = document.getElementById('ElarisPurchaseSubscribe-' + sectionId);
      var mainBox = document.getElementById('ElarisMainImage-' + sectionId);
      var mainImg = document.getElementById('ElarisMainImgTag-' + sectionId);

      function setQty(n) {
        n = Math.max(1, parseInt(n, 10) || 1);
        if (qtyInput) qtyInput.value = n;
        if (qtyDisplay) qtyDisplay.textContent = String(n);
      }

      var minus = document.getElementById('ElarisQtyMinus-' + sectionId);
      var plus = document.getElementById('ElarisQtyPlus-' + sectionId);
      if (minus)
        minus.addEventListener('click', function () {
          setQty((parseInt(qtyInput.value, 10) || 1) - 1);
        });
      if (plus)
        plus.addEventListener('click', function () {
          setQty((parseInt(qtyInput.value, 10) || 1) + 1);
        });

      if (variantSelect && variantInput) {
        variantSelect.addEventListener('change', function () {
          variantInput.value = variantSelect.value;
          syncVariantUi(variantById(variantSelect.value));
        });
      }

      function setPurchaseMode(mode) {
        if (!btnOnetime || !btnSubscribe) return;
        btnOnetime.classList.toggle('active', mode === 'onetime');
        btnSubscribe.classList.toggle('active', mode === 'subscribe');
        if (sellingPlanInput) {
          if (mode === 'subscribe' && btnSubscribe.getAttribute('data-selling-plan-id')) {
            sellingPlanInput.value = btnSubscribe.getAttribute('data-selling-plan-id');
          } else {
            sellingPlanInput.value = '';
          }
        }
      }

      if (btnOnetime) btnOnetime.addEventListener('click', function () { setPurchaseMode('onetime'); });
      if (btnSubscribe) {
        btnSubscribe.addEventListener('click', function () {
          if (btnSubscribe.getAttribute('data-mode') === 'subscribe-placeholder') {
            if (btnOnetime) btnOnetime.classList.remove('active');
            btnSubscribe.classList.add('active');
            if (sellingPlanInput) sellingPlanInput.value = '';
            return;
          }
          setPurchaseMode('subscribe');
        });
      }

      var thumbs = document.querySelectorAll('#ElarisThumbs-' + sectionId + ' .thumb');
      thumbs.forEach(function (t) {
        t.addEventListener('click', function () {
          var src = t.getAttribute('data-image-src');
          var alt = t.getAttribute('data-image-alt') || '';
          if (!mainBox || !src) return;
          thumbs.forEach(function (x) { x.classList.remove('is-active'); });
          t.classList.add('is-active');
          if (mainImg) {
            mainImg.src = src;
            mainImg.alt = alt;
          } else {
            mainBox.innerHTML = '<img id="ElarisMainImgTag-' + sectionId + '" src="' + src + '" alt="' + alt.replace(/"/g, '&quot;') + '" loading="lazy" style="width:100%;height:100%;object-fit:contain;">';
            mainImg = document.getElementById('ElarisMainImgTag-' + sectionId);
            mainBox.classList.add('has-image');
          }
        });
      });

      var regrowthStrip = document.getElementById('ElarisRegrowthStrip-' + sectionId);
      var regrowthPrev = document.getElementById('ElarisRegrowthPrev-' + sectionId);
      var regrowthNext = document.getElementById('ElarisRegrowthNext-' + sectionId);
      function scrollRegrowthThumbStrip(dir) {
        if (!regrowthStrip) return;
        var step = Math.max(120, Math.floor(regrowthStrip.clientWidth * 0.35));
        regrowthStrip.scrollBy({ left: dir === 'next' ? step : -step, behavior: 'smooth' });
      }
      if (regrowthPrev) regrowthPrev.addEventListener('click', function () { scrollRegrowthThumbStrip('prev'); });
      if (regrowthNext) regrowthNext.addEventListener('click', function () { scrollRegrowthThumbStrip('next'); });

      if (window.innerWidth > 1024) {
        document.querySelectorAll('.elaris-product-page .footer-accordion').forEach(function (el) {
          el.setAttribute('open', '');
        });
      } else {
        document.querySelectorAll('.elaris-product-page .footer-accordion').forEach(function (el) {
          el.removeAttribute('open');
        });
      }

      document.querySelectorAll('.elaris-product-page .collection-item--toggle').forEach(function (item) {
        var toggle = item.querySelector('[data-collection-toggle]');
        if (!toggle) return;

        function setOpen(open) {
          item.classList.toggle('is-open', open);
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        }

        function handleToggle(event) {
          event.preventDefault();
          setOpen(!item.classList.contains('is-open'));
        }

        toggle.addEventListener('click', handleToggle);
        item.addEventListener('click', function (event) {
          if (event.target === toggle || toggle.contains(event.target)) return;
          handleToggle(event);
        });
      });
    })();
  </script>
{% endif %}

