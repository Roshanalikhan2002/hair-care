{{ 'elaris-home.css' | asset_url | stylesheet_tag }}
{% style %}
/* Hair Care Bundle page — scoped layout; brand #580514 + cream (match bundle.html) */
.elaris-bundle-wrapper {
  font-family: Inter, Arial, Helvetica, sans-serif;
  background: #fafaf8;
  color: #580514;
  min-height: 100vh;
}

.bundle-hero {
  display: flex;
  align-items: stretch;
  min-height: calc(100vh - 1px);
  max-width: 1440px;
  margin: 0 auto;
}

.bundle-image-col {
  width: 50%;
  position: sticky;
  top: 0;
  height: 100vh;
  flex-shrink: 0;
  background: rgba(88, 5, 20, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bundle-image-col__inner {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(88, 5, 20, 0.08) 0%, rgba(88, 5, 20, 0.14) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bundle-image-col__inner img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.bundle-info-col {
  width: 50%;
  max-height: 100vh;
  overflow-y: auto;
  padding: 60px 52px;
  background: #ffffff;
  scrollbar-width: thin;
  scrollbar-color: rgba(88, 5, 20, 0.35) transparent;
}

.bundle-badge {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(88, 5, 20, 0.55);
  margin-bottom: 14px;
}

.bundle-title {
  font-size: 38px;
  font-weight: 700;
  line-height: 1.15;
  color: #580514;
  margin: 0 0 18px;
}

.bundle-stars {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 22px;
}

.bundle-stars .stars {
  color: #8b1a2e;
  font-size: 18px;
  letter-spacing: 2px;
}

.bundle-stars .count {
  font-size: 14px;
  color: rgba(88, 5, 20, 0.72);
}

.bundle-desc {
  font-size: 14.5px;
  line-height: 1.75;
  color: rgba(88, 5, 20, 0.88);
  margin: 0 0 32px;
}

.bundle-cta {
  display: block;
  text-align: center;
  padding: 17px 28px;
  border: 2px solid #580514;
  border-radius: 50px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #580514;
  text-decoration: none;
  margin-bottom: 36px;
  transition: background 0.25s, color 0.25s;
}

.bundle-cta:hover {
  background: #580514;
  color: #fff;
}

.bundle-divider {
  border: none;
  border-top: 1px solid rgba(88, 5, 20, 0.15);
  margin-bottom: 28px;
}

.bundle-acc {
  border-top: 1px solid rgba(88, 5, 20, 0.15);
}

.bundle-acc:last-of-type {
  border-bottom: 1px solid rgba(88, 5, 20, 0.15);
}

.bundle-acc > summary {
  width: 100%;
  background: none;
  border: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 0;
  cursor: pointer;
  font-family: inherit;
  list-style: none;
}

.bundle-acc > summary::-webkit-details-marker {
  display: none;
}

.bundle-acc > summary .bundle-acc__label {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #580514;
}

.bundle-acc > summary .bundle-acc__icon {
  font-size: 0;
  flex-shrink: 0;
}

.bundle-acc > summary .bundle-acc__icon::after {
  font-size: 20px;
  font-weight: 300;
  color: #580514;
  content: '+';
}

details.bundle-acc[open] > summary .bundle-acc__icon::after {
  content: '−';
}

.bundle-acc__panel {
  padding-bottom: 18px;
  font-size: 14px;
  line-height: 1.8;
  color: rgba(88, 5, 20, 0.85);
}

.bundle-acc__panel ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.bundle-acc__panel li {
  padding: 6px 0;
  border-bottom: 1px solid rgba(88, 5, 20, 0.1);
}

.bundle-acc__panel li:last-child {
  border-bottom: none;
}

.bundle-info-spacer {
  height: 60px;
}

.bundle-ingredients {
  display: flex;
  align-items: stretch;
  min-height: 520px;
  max-width: 1440px;
  margin: 0 auto;
  background: rgba(88, 5, 20, 0.04);
}

.bundle-ingredients__list {
  width: 50%;
  padding: 64px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.bundle-ingredients__kicker {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(88, 5, 20, 0.55);
  margin-bottom: 10px;
}

.bundle-ingredients__title {
  font-size: 26px;
  font-weight: 700;
  color: #580514;
  margin: 0 0 36px;
  line-height: 1.3;
}

.bundle-ingredient-row {
  display: flex;
  gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(88, 5, 20, 0.12);
}

.bundle-ingredient-row:last-child {
  border-bottom: none;
}

.bundle-ingredient-row__label {
  font-size: 14px;
  font-weight: 600;
  color: #580514;
  min-width: 130px;
}

.bundle-ingredient-row__value {
  font-size: 14px;
  color: #580514;
  margin: 0;
}

.bundle-ingredients__visual {
  width: 50%;
  background: rgba(88, 5, 20, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400px;
}

.bundle-ingredients__visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  min-height: 400px;
}

.bundle-faq-wrap {
  max-width: 780px;
  margin: 0 auto;
  padding: 80px 40px;
}

.bundle-faq__kicker {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(88, 5, 20, 0.55);
  margin-bottom: 10px;
  text-align: center;
}

.bundle-faq__title {
  font-size: 32px;
  font-weight: 700;
  color: #580514;
  text-align: center;
  margin: 0 0 52px;
}

.bundle-faq-item {
  border-top: 1px solid rgba(88, 5, 20, 0.15);
}

.bundle-faq-item:last-child {
  border-bottom: 1px solid rgba(88, 5, 20, 0.15);
}

.bundle-faq-item > summary {
  width: 100%;
  background: none;
  border: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
  cursor: pointer;
  font-family: inherit;
  text-align: left;
  list-style: none;
}

.bundle-faq-item > summary::-webkit-details-marker {
  display: none;
}

.bundle-faq-item__q {
  font-size: 15px;
  font-weight: 500;
  color: #580514;
  padding-right: 20px;
}

.bundle-faq-item__icon {
  font-size: 0;
  font-weight: 300;
  color: #580514;
  flex-shrink: 0;
}

.bundle-faq-item__icon::after {
  font-size: 22px;
  content: '+';
}

details.bundle-faq-item[open] > summary .bundle-faq-item__icon::after {
  content: '−';
}

.bundle-faq-item__a {
  padding-bottom: 20px;
  font-size: 14px;
  line-height: 1.8;
  color: rgba(88, 5, 20, 0.85);
}

@media (max-width: 768px) {
  .bundle-hero {
    flex-direction: column;
  }

  .bundle-image-col {
    position: static;
    height: 380px;
    width: 100%;
  }

  .bundle-info-col {
    width: 100%;
    max-height: none;
    overflow-y: visible;
    padding: 28px 20px;
  }

  .bundle-ingredients {
    flex-direction: column;
  }

  .bundle-ingredients__list {
    width: 100%;
    padding: 32px 20px;
  }

  .bundle-ingredients__visual {
    width: 100%;
    min-height: 280px;
  }

  .bundle-faq-wrap {
    padding: 40px 20px;
  }

  .bundle-faq__title {
    font-size: 24px;
  }

  .bundle-title {
    font-size: 28px;
  }
}
{% endstyle %}
{{ 'elaris-footer.css' | asset_url | stylesheet_tag }}

<div class="elaris-home-root elaris-bundle-wrapper" id="BundlePage-{{ section.id }}">
  <header class="navbar">
    <div class="left-nav">
      <button type="button" aria-label="menu" class="menu-btn">&#9776;</button>
      <div class="logo">
        <a href="{{ routes.root_url }}">{% render 'elaris-logo-text', section: section %}</a>
      </div>
    </div>
    <nav class="desktop-nav">
      <a href="{{ section.settings.nav_shop_url | default: routes.all_products_collection_url }}">Shop</a>
      <a href="{{ section.settings.nav_offers_url | default: '#' }}">Offers</a>
      <a href="{{ section.settings.nav_learn_url | default: '#' }}">Learn</a>
      <a href="{{ section.settings.nav_quiz_url | default: '#' }}">Hair Quiz</a>
      <a href="{{ section.settings.nav_pros_url | default: '#' }}">Pros</a>
    </nav>
    <div class="icons">
      <a href="{{ routes.search_url }}" aria-label="search">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>
      <a href="{{ routes.account_login_url }}" class="profile" aria-label="account">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </a>
      <a href="{{ routes.cart_url }}" class="elaris-cart-trigger" aria-label="cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span class="elaris-cart-count" data-elaris-cart-count>{% if cart.item_count > 0 %}{{ cart.item_count }}{% endif %}</span>
      </a>
    </div>
  </header>

  {% liquid
    assign bundle_cta = section.settings.cta_url | strip
    if bundle_cta == blank and product != blank
      assign bundle_cta = routes.cart_add_url | append: '?id=' | append: product.selected_or_first_available_variant.id | append: '&quantity=1'
    endif
    if bundle_cta == blank
      assign bundle_cta = '#'
    endif
  %}

  <section class="bundle-hero">
    <div class="bundle-image-col">
      <div class="bundle-image-col__inner">
        {% if section.settings.hero_media_image != blank %}
          <img
            src="{{ section.settings.hero_media_image | image_url: width: 1600 }}"
            alt="{{ section.settings.hero_heading | escape }}"
            width="{{ section.settings.hero_media_image.width }}"
            height="{{ section.settings.hero_media_image.height }}"
            loading="eager"
          >
        {% elsif product != blank and product.featured_media %}
          <img
            src="{{ product.featured_media | image_url: width: 1600 }}"
            alt="{{ product.title | escape }}"
            width="{{ product.featured_media.width }}"
            height="{{ product.featured_media.height }}"
            loading="eager"
          >
        {% endif %}
      </div>
    </div>

    <div class="bundle-info-col">
      {% if section.settings.hero_badge != blank %}
        <p class="bundle-badge">{{ section.settings.hero_badge }}</p>
      {% endif %}

      <h1 class="bundle-title">{{ section.settings.hero_heading }}</h1>

      <div class="bundle-stars">
        <span class="stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        {% if section.settings.rating_count != blank %}
          <span class="count">{{ section.settings.rating_count }}</span>
        {% endif %}
      </div>

      {% if section.settings.hero_description != blank %}
        <div class="bundle-desc">{{ section.settings.hero_description | newline_to_br }}</div>
      {% endif %}

      {% if section.settings.cta_label != blank %}
        {% liquid
          assign cta_display = section.settings.cta_label
          if product != blank
            assign price_fmt = product.selected_or_first_available_variant.price | money
            assign cta_display = cta_display | replace: '{price}', price_fmt
          else
            assign cta_display = cta_display | replace: '{price}', '' | strip
          endif
        %}
        <a class="bundle-cta" href="{{ bundle_cta }}">{{ cta_display }}</a>
      {% endif %}

      <hr class="bundle-divider">

      {% if section.settings.acc1_title != blank %}
        <details class="bundle-acc">
          <summary>
            <span class="bundle-acc__label">{{ section.settings.acc1_title }}</span>
            <span class="bundle-acc__icon" aria-hidden="true"></span>
          </summary>
          <div class="bundle-acc__panel">
            {% if section.settings.acc1_body != blank %}
              {{ section.settings.acc1_body | newline_to_br }}
            {% else %}
              <p>The E7 Hair Care Set includes three full-size products in a sleek elaréhair pouch: E7 Anti Frizz Keratin Serum, E7 Hair Regrowth Spray, and E7 Floral Blossom Hair Mist.</p>
            {% endif %}
          </div>
        </details>
      {% endif %}

      {% if section.settings.acc2_title != blank %}
        <details class="bundle-acc">
          <summary>
            <span class="bundle-acc__label">{{ section.settings.acc2_title }}</span>
            <span class="bundle-acc__icon" aria-hidden="true"></span>
          </summary>
          <div class="bundle-acc__panel">
            {% if section.settings.acc2_body != blank %}
              {{ section.settings.acc2_body | newline_to_br }}
            {% else %}
              <p><strong>Step 1:</strong> Apply the Hair Growth Serum directly to scalp, massage gently for 2–3 minutes.</p>
              <p><strong>Step 2:</strong> Shampoo with the Repair Shampoo, lather and rinse thoroughly.</p>
              <p><strong>Step 3:</strong> Apply the Deep Conditioning Mask to lengths, leave for 5–10 minutes, rinse.</p>
            {% endif %}
          </div>
        </details>
      {% endif %}

      {% if section.settings.acc3_title != blank %}
        <details class="bundle-acc">
          <summary>
            <span class="bundle-acc__label">{{ section.settings.acc3_title }}</span>
            <span class="bundle-acc__icon" aria-hidden="true"></span>
          </summary>
          <div class="bundle-acc__panel">
            {% if section.settings.acc3_body != blank %}
              {{ section.settings.acc3_body | newline_to_br }}
            {% else %}
              <p>Free shipping on orders above Rs.10,000. Standard delivery 3–5 business days. Returns accepted within 7 days of delivery for unopened items.</p>
            {% endif %}
          </div>
        </details>
      {% endif %}

      <div class="bundle-info-spacer"></div>
    </div>
  </section>

  <section class="bundle-ingredients">
    <div class="bundle-ingredients__list">
      {% if section.settings.ingredients_kicker != blank %}
        <p class="bundle-ingredients__kicker">{{ section.settings.ingredients_kicker }}</p>
      {% endif %}
      {% if section.settings.ingredients_heading != blank %}
        <h2 class="bundle-ingredients__title">{{ section.settings.ingredients_heading }}</h2>
      {% endif %}

      {% assign ingredient_blocks = section.blocks | where: 'type', 'ingredient' %}
      {% if ingredient_blocks.size > 0 %}
        <div class="bundle-ingredient-rows">
          {% for block in ingredient_blocks %}
            <div class="bundle-ingredient-row" {{ block.shopify_attributes }}>
              <span class="bundle-ingredient-row__label">{{ block.settings.label }}</span>
              <span class="bundle-ingredient-row__value">{{ block.settings.value }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="bundle-ingredients__visual">
      {% if section.settings.ingredients_image != blank %}
        <img
          src="{{ section.settings.ingredients_image | image_url: width: 1400 }}"
          alt=""
          width="{{ section.settings.ingredients_image.width }}"
          height="{{ section.settings.ingredients_image.height }}"
          loading="lazy"
        >
      {% else %}
        <img
          src="{{ 'bundle-ingredients-image.jpg' | asset_url }}"
          alt="elaréhair hair care bundle ingredients"
          width="1400"
          height="1400"
          loading="lazy"
        >
      {% endif %}
    </div>
  </section>

  <section class="bundle-faq-wrap">
    {% if section.settings.faq_kicker != blank %}
      <p class="bundle-faq__kicker">{{ section.settings.faq_kicker }}</p>
    {% endif %}
    {% if section.settings.faq_heading != blank %}
      <h2 class="bundle-faq__title">{{ section.settings.faq_heading }}</h2>
    {% endif %}

    {% assign faq_blocks = section.blocks | where: 'type', 'bundle_faq' %}
    {% for block in faq_blocks %}
      <details class="bundle-faq-item" {{ block.shopify_attributes }}>
        <summary>
          <span class="bundle-faq-item__q">{{ block.settings.question }}</span>
          <span class="bundle-faq-item__icon" aria-hidden="true"></span>
        </summary>
        <div class="bundle-faq-item__a">{{ block.settings.answer | newline_to_br }}</div>
      </details>
    {% endfor %}
  </section>

  {% render 'elaris-footer' %}
</div>

{% schema %}
{
  "name": "Hair Care Bundle",
  "tag": "section",
  "class": "elaris-bundle-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Use as a Page template (Pages → template: hair-care-bundle) or as a Product template (Products → Theme template: hair-care-bundle). For products, create a product (e.g. “Hair Care Bundle”) and assign this template."
    },
    {
      "type": "header",
      "content": "Header navigation"
    },
    {
      "type": "url",
      "id": "nav_shop_url",
      "label": "Shop link"
    },
    {
      "type": "url",
      "id": "nav_offers_url",
      "label": "Offers link"
    },
    {
      "type": "url",
      "id": "nav_learn_url",
      "label": "Learn link"
    },
    {
      "type": "url",
      "id": "nav_quiz_url",
      "label": "Hair Quiz link"
    },
    {
      "type": "url",
      "id": "nav_pros_url",
      "label": "Pros link"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "elaréhair",
      "info": "Shown in the header. Leave as default or match your theme settings."
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_media_image",
      "label": "Hero image (left column)"
    },
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Badge",
      "default": "Complete System"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Heading",
      "default": "Hair Care Bundle"
    },
    {
      "type": "text",
      "id": "rating_count",
      "label": "Rating line (e.g. review count)",
      "default": "(1,430)"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Description",
      "default": "Transform your hair routine with the E7 Hair Care Set. This three-product collection is designed to control frizz, strengthen roots, and leave your hair feeling soft, shiny, and beautifully scented. Each product works on its own or together—perfect for home or on-the-go use."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Buy the Kit – {price}",
      "info": "Use {price} where the product price should appear (updates from Shopify). On a Page (no product), {price} is removed."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Hero accordions"
    },
    {
      "type": "text",
      "id": "acc1_title",
      "label": "Accordion 1 title",
      "default": "What's Inside"
    },
    {
      "type": "textarea",
      "id": "acc1_body",
      "label": "Accordion 1 content (optional, plain text)"
    },
    {
      "type": "text",
      "id": "acc2_title",
      "label": "Accordion 2 title",
      "default": "The Routine"
    },
    {
      "type": "textarea",
      "id": "acc2_body",
      "label": "Accordion 2 content (optional, plain text)"
    },
    {
      "type": "text",
      "id": "acc3_title",
      "label": "Accordion 3 title",
      "default": "Shipping & Returns"
    },
    {
      "type": "textarea",
      "id": "acc3_body",
      "label": "Accordion 3 content (optional, plain text)"
    },
    {
      "type": "header",
      "content": "Ingredients band"
    },
    {
      "type": "text",
      "id": "ingredients_kicker",
      "label": "Kicker",
      "default": "Key Ingredients"
    },
    {
      "type": "text",
      "id": "ingredients_heading",
      "label": "Heading",
      "default": "Powered by Nature & Science"
    },
    {
      "type": "image_picker",
      "id": "ingredients_image",
      "label": "Right column image"
    },
    {
      "type": "header",
      "content": "FAQ"
    },
    {
      "type": "text",
      "id": "faq_kicker",
      "label": "FAQ kicker",
      "default": "Got Questions?"
    },
    {
      "type": "text",
      "id": "faq_heading",
      "label": "FAQ heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Name",
          "default": "Almond Oil"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Description",
          "default": "Softness and strength"
        }
      ]
    },
    {
      "type": "bundle_faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does one bundle last?"
        },
        {
