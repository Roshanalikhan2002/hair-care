{{ 'elaris-home.css' | asset_url | stylesheet_tag }}
{{ 'elaris-footer.css' | asset_url | stylesheet_tag }}
{{ 'elaris-collection.css' | asset_url | stylesheet_tag }}

{% liquid
  assign collection_heading = section.settings.heading | strip
  if collection_heading == blank
    if collection.title != blank
      assign collection_heading = collection.title
    else
      assign collection_heading = 'Shop All'
    endif
  endif

  assign collection_subheading = section.settings.subheading | strip
  if collection_subheading == blank and collection.description != blank
    assign collection_subheading = collection.description | strip_html | truncate: 200
  endif

  assign fallback_handles = 'hair-care-bundle,floral-blossom-hair-mist,anti-frizz-keratin-serum,hair-regrowth-spray' | split: ','
%}

<div class="elaris-collection-root elaris-home-root">
  {% render 'elaris-navbar', section: section %}

  <div class="elaris-collection-hero">
    <h1>{{ collection_heading }}</h1>
    {% if collection_subheading != blank %}
      <p>{{ collection_subheading }}</p>
    {% endif %}
  </div>

  {% if collection.products_count > 0 %}
    <section class="product-cards" aria-label="{{ collection_heading | escape }}">
      {% for product in collection.products %}
        {% render 'elaris-collection-product-card', product: product, button_label: section.settings.button_label_prefix %}
      {% endfor %}
    </section>
  {% else %}
    <section class="product-cards" aria-label="{{ collection_heading | escape }}">
      {% for fallback_handle in fallback_handles %}
        {% assign fallback_product = all_products[fallback_handle] %}
        {% if fallback_product != blank %}
          {% render 'elaris-collection-product-card', product: fallback_product, button_label: section.settings.button_label_prefix %}
        {% endif %}
      {% endfor %}
    </section>
    {% if fallback_handles.size > 0 %}
      {% assign any_fallback = false %}
      {% for fallback_handle in fallback_handles %}
        {% if all_products[fallback_handle] != blank %}
          {% assign any_fallback = true %}
        {% endif %}
      {% endfor %}
      {% unless any_fallback %}
        <p class="elaris-collection-empty">No products in this collection yet.</p>
      {% endunless %}
    {% endif %}
  {% endif %}

  {% render 'elaris-footer' %}
</div>

<script>
  (function () {
    if (window.innerWidth > 1024) {
      document.querySelectorAll('.elaris-collection-root .footer-accordion').forEach(function (el) {
        el.setAttribute('open', '');
      });
    }

    document.querySelectorAll('.elaris-collection-root .card[data-card-url]').forEach(function (card) {
      card.addEventListener('click', function (event) {
        if (event.target.closest('a')) return;
        var to = card.getAttribute('data-card-url');
        if (to) window.location.href = to;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "ELARÉHAIR collection",
  "tag": "section",
  "class": "elaris-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "ELARÉHAIR"
    },
    {
      "type": "header",
      "content": "Navigation URLs"
    },
    {
      "type": "url",
      "id": "nav_shop_url",
      "label": "Shop link"
    },
    {
      "type": "url",
      "id": "nav_offers_url",
      "label": "Offers link"
    },
    {
      "type": "url",
      "id": "nav_learn_url",
      "label": "Learn link"
    },
    {
      "type": "url",
      "id": "nav_quiz_url",
      "label": "Hair Quiz link"
    },
    {
      "type": "url",
      "id": "nav_pros_url",
      "label": "Pros link"
    },
    {
      "type": "header",
      "content": "Collection header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave empty to use the collection title from Shopify."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "info": "Leave empty to use the collection description."
    },
    {
      "type": "text",
      "id": "button_label_prefix",
      "label": "Button label prefix",
      "default": "BUY"
    }
  ],
  "presets": [
    {
      "name": "ELARÉHAIR collection"
    }
  ]
}
{% endschema %}
