{{ 'elaris-home.css' | asset_url | stylesheet_tag }}
{{ 'elaris-footer.css' | asset_url | stylesheet_tag }}
{{ 'elaris-contact.css' | asset_url | stylesheet_tag }}

{% liquid
  assign page_heading = section.settings.heading | strip
  if page_heading == blank
    if page.title != blank
      assign page_heading = page.title
    else
      assign page_heading = 'Contact Us'
    endif
  endif

  assign page_intro = section.settings.intro | strip
  if page_intro == blank
    assign page_intro = "We're always here for you — with care, clarity, and a warm heart. Whether you have a question, need help with an order, or just want to say Salam — reach out anytime."
  endif

  assign contact_email = section.settings.email | strip
  if contact_email == blank
    assign contact_email = 'iibdaeielaris7@gmail.com'
  endif

  assign email_note = section.settings.email_note | strip
  assign whatsapp = section.settings.whatsapp | strip
  assign whatsapp_note = section.settings.whatsapp_note | strip
  assign contact_hours = section.settings.hours | strip
  assign registered_brand = section.settings.registered_brand | strip
  assign brand_note = section.settings.brand_note | strip
  assign thank_you = section.settings.thank_you | strip

  if whatsapp != blank
    assign whatsapp_digits = whatsapp | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' | replace: '+', ''
    assign wa_first_digit = whatsapp_digits | slice: 0, 1
    if whatsapp_digits.size >= 11 and wa_first_digit == '0'
      assign whatsapp_href = 'https://wa.me/92' | append: whatsapp_digits | slice: 1, 20
    else
      assign whatsapp_href = 'https://wa.me/' | append: whatsapp_digits
    endif
  endif
%}

<div class="elaris-contact-root elaris-home-root">
  {% render 'elaris-navbar', section: section %}

  <main class="elaris-contact-main">
    <div class="elaris-contact-hero">
      <h1>{{ page_heading }}</h1>
      <p class="elaris-contact-intro">{% render 'elaris-brandize', text: page_intro %}</p>
    </div>

    <div class="elaris-contact-grid">
      <aside class="elaris-contact-info">
        {% if contact_email != blank %}
          <div class="elaris-contact-detail">
            <h3>{{ section.settings.email_heading | default: 'Email Support' }}</h3>
            <p class="elaris-contact-value"><a href="mailto:{{ contact_email }}">{{ contact_email }}</a></p>
            {% if email_note != blank %}
              <p class="elaris-contact-note">{% render 'elaris-brandize', text: email_note %}</p>
            {% endif %}
          </div>
        {% endif %}

        {% if whatsapp != blank %}
          <div class="elaris-contact-detail">
            <h3>{{ section.settings.whatsapp_heading | default: 'WhatsApp Support' }}</h3>
            <p class="elaris-contact-value">
              <a href="{{ whatsapp_href }}" rel="noopener noreferrer" target="_blank">{{ whatsapp }}</a>
            </p>
            {% if whatsapp_note != blank %}
              <p class="elaris-contact-note">{% render 'elaris-brandize', text: whatsapp_note %}</p>
            {% endif %}
          </div>
        {% endif %}

        {% if contact_hours != blank %}
          <div class="elaris-contact-detail">
            <h3>{{ section.settings.hours_heading | default: 'Support Hours' }}</h3>
            <p class="elaris-contact-value">{% render 'elaris-brandize', text: contact_hours %}</p>
          </div>
        {% endif %}

        {% if registered_brand != blank %}
          <div class="elaris-contact-detail">
            <h3>{{ section.settings.registered_heading | default: 'Registered Brand' }}</h3>
            <p class="elaris-contact-value">{% render 'elaris-brandize', text: registered_brand %}</p>
            {% if brand_note != blank %}
              <p class="elaris-contact-note">{% render 'elaris-brandize', text: brand_note %}</p>
            {% endif %}
          </div>
        {% endif %}

        {% if thank_you != blank %}
          <p class="elaris-contact-thanks">{% render 'elaris-brandize', text: thank_you %}</p>
        {% endif %}
      </aside>

      <div class="elaris-contact-form-wrap">
        <h2>{{ section.settings.form_heading | default: 'Send a message' }}</h2>

        {% form 'contact', class: 'elaris-contact-form' %}
          {% if form.posted_successfully? %}
            <div class="elaris-contact-alert elaris-contact-alert--success" role="status">
              {{ section.settings.success_message | default: 'Thanks for reaching out. We will reply to your email shortly.' }}
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="elaris-contact-alert elaris-contact-alert--error" role="alert">
              <p>{{ section.settings.error_message | default: 'Please fix the errors below and try again.' }}</p>
              <ul>
                {% for field in form.errors %}
                  <li>{{ form.errors.messages[field] }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          {% unless form.posted_successfully? %}
            <div class="field-row">
              <div class="field">
                <label for="ContactForm-name-{{ section.id }}">Name</label>
                <input
                  type="text"
                  id="ContactForm-name-{{ section.id }}"
                  name="contact[name]"
                  autocomplete="name"
                  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                  placeholder="Your name"
                  required
                >
              </div>
              <div class="field">
                <label for="ContactForm-email-{{ section.id }}">Email</label>
                <input
                  type="email"
                  id="ContactForm-email-{{ section.id }}"
                  name="contact[email]"
                  autocomplete="email"
                  value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                  placeholder="you@example.com"
                  required
                  {% if form.errors contains 'email' %}
                    aria-invalid="true"
                  {% endif %}
                >
              </div>
            </div>

            <div class="field">
              <label for="ContactForm-phone-{{ section.id }}">Phone <span style="font-weight:400;text-transform:none;letter-spacing:0;">(optional)</span></label>
              <input
                type="tel"
                id="ContactForm-phone-{{ section.id }}"
                name="contact[phone]"
                autocomplete="tel"
                value="{% if form.phone %}{{ form.phone }}{% endif %}"
                placeholder="+92 ..."
              >
            </div>

            <div class="field">
              <label for="ContactForm-body-{{ section.id }}">Message</label>
              <textarea
                id="ContactForm-body-{{ section.id }}"
                name="contact[body]"
                placeholder="How can we help?"
                required
                {% if form.errors contains 'body' %}
                  aria-invalid="true"
                {% endif %}
              >{% if form.body %}{{ form.body }}{% endif %}</textarea>
            </div>

            <button type="submit" class="elaris-contact-submit">
              {{ section.settings.submit_label | default: 'Send message' }}
            </button>
          {% endunless %}
        {% endform %}
      </div>
    </div>
  </main>

  {% render 'elaris-footer' %}
</div>

<script>
  (function () {
    if (window.innerWidth > 1024) {
      document.querySelectorAll('.elaris-contact-root .footer-accordion').forEach(function (el) {
        el.setAttribute('open', '');
      });
    }
  })();
</script>

