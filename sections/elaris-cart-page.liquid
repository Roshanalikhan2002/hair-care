<div class="elaris-cart-page-root">
  {% render 'elaris-navbar', section: section %}

  <main class="elaris-cart-page">
    <h1 class="elaris-cart-page__title">Your bag</h1>

    {% if cart.item_count == 0 %}
      <div class="elaris-cart-page__empty">
        <p>Your bag is empty.</p>
        <a href="{{ routes.all_products_collection_url }}">Continue shopping</a>
      </div>
    {% else %}
      <ul class="elaris-cart-page__lines elaris-cart-drawer__lines" id="ElarisCartPageLines">
        {% for item in cart.items %}
          <li class="elaris-cart-drawer__line" data-line-key="{{ item.key }}">
            <a href="{{ item.url }}" class="elaris-cart-drawer__thumb" tabindex="-1">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 180 }}" alt="{{ item.image.alt | default: item.title | escape }}" width="90" height="90" loading="lazy">
              {% else %}
                <span class="elaris-cart-drawer__thumb-fallback"></span>
              {% endif %}
            </a>
            <div class="elaris-cart-drawer__line-body">
              <a href="{{ item.url }}" class="elaris-cart-drawer__line-title">{{ item.product.title | escape }}</a>
              {% unless item.product.has_only_default_variant %}
                <div class="elaris-cart-drawer__line-variant">{{ item.variant.title | escape }}</div>
              {% endunless %}
              <div class="elaris-cart-drawer__line-meta">
                <div class="elaris-cart-drawer__qty">
                  <button type="button" data-line-key="{{ item.key }}" data-qty-change="-1" aria-label="Decrease quantity">−</button>
                  <span data-line-qty>{{ item.quantity }}</span>
                  <button type="button" data-line-key="{{ item.key }}" data-qty-change="1" aria-label="Increase quantity">+</button>
                </div>
                <button type="button" class="elaris-cart-drawer__remove" data-line-key="{{ item.key }}" data-remove-line aria-label="Remove">Remove</button>
              </div>
            </div>
            <div class="elaris-cart-drawer__line-price{% if item.final_line_price == 0 %} elaris-cart-drawer__line-price--free{% endif %}">
              {% if item.final_line_price == 0 %}
                FREE
              {% else %}
                {{ item.final_line_price | money }}
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ul>

      <div class="elaris-cart-page__foot" data-elaris-cart-page-foot>
        <div class="elaris-cart-page__subtotal">
          <span>Subtotal</span>
          <strong data-elaris-cart-page-subtotal>{{ cart.total_price | money }}</strong>
        </div>
        <p class="elaris-cart-page__note">Shipping &amp; taxes calculated at checkout.</p>
        {% form 'cart', cart, class: 'elaris-cart-drawer__checkout-form' %}
          <button type="submit" name="checkout" class="elaris-cart-page__checkout">Checkout</button>
        {% endform %}
      </div>
    {% endif %}
  </main>

  {% render 'elaris-footer' %}
</div>

{% schema %}
{
  "name": "ELARÉ cart",
  "tag": "section",
  "class": "elaris-cart-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "ELARÉ"
    }
  ]
}
{% endschema %}
