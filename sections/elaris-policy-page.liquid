{{ 'elaris-home.css' | asset_url | stylesheet_tag }}
{{ 'elaris-footer.css' | asset_url | stylesheet_tag }}
{{ 'elaris-policy.css' | asset_url | stylesheet_tag }}

{% liquid
  assign page_heading = section.settings.heading | strip
  if page_heading == blank
    if page.title != blank
      assign page_heading = page.title
    else
      assign page_heading = 'Policy'
    endif
  endif
%}

<div class="elaris-policy-root elaris-home-root">
  {% render 'elaris-navbar', section: section %}

  <main class="elaris-policy-main">
    <header class="elaris-policy-hero">
      <h1>{{ page_heading }}</h1>
      {% if section.settings.intro != blank %}
        <p class="elaris-policy-intro">{% render 'elaris-brandize', text: section.settings.intro %}</p>
      {% endif %}
    </header>

    <div class="elaris-policy-content">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'section' %}
            <section class="elaris-policy-block" {{ block.shopify_attributes }}>
              {% if block.settings.title != blank %}
                <h2>{% render 'elaris-brandize', text: block.settings.title %}</h2>
              {% endif %}
              {% if block.settings.body != blank %}
                <div class="elaris-policy-body rte">
                  {{ block.settings.body | replace: 'Elaris7', 'ELARÉHAIR' | replace: 'ELARIS7', 'ELARÉHAIR' }}
                </div>
              {% endif %}
            </section>
          {% when 'updated' %}
            <p class="elaris-policy-updated" {{ block.shopify_attributes }}>
              {% render 'elaris-brandize', text: block.settings.text %}
            </p>
          {% when 'closing' %}
            <section class="elaris-policy-closing" {{ block.shopify_attributes }}>
              {% if block.settings.title != blank %}
                <h2>{% render 'elaris-brandize', text: block.settings.title %}</h2>
              {% endif %}
              {% if block.settings.body != blank %}
                <p>{% render 'elaris-brandize', text: block.settings.body %}</p>
              {% endif %}
              <ul class="elaris-policy-contact">
                {% if block.settings.email != blank %}
                  <li>Email: <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a></li>
                {% endif %}
                {% if block.settings.whatsapp != blank %}
                  <li>WhatsApp: <a href="tel:{{ block.settings.whatsapp | replace: ' ', '' }}">{{ block.settings.whatsapp }}</a></li>
                {% endif %}
              </ul>
              {% if block.settings.footer_note != blank %}
                <p class="elaris-policy-footer-note">{% render 'elaris-brandize', text: block.settings.footer_note %}</p>
              {% endif %}
            </section>
        {% endcase %}
      {% endfor %}
    </div>
  </main>

  {% render 'elaris-footer' %}
</div>

<script>
  (function () {
    if (window.innerWidth > 1024) {
      document.querySelectorAll('.elaris-policy-root .footer-accordion').forEach(function (el) {
        el.setAttribute('open', '');
      });
    }
  })();
</script>

{% schema %}
{
  "name": "ELARÉHAIR policy page",
  "tag": "section",
  "class": "elaris-policy-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "ELARÉHAIR"
    },
    {
      "type": "header",
      "content": "Navigation URLs"
    },
    {
      "type": "url",
      "id": "nav_shop_url",
      "label": "Shop link"
    },
    {
      "type": "url",
      "id": "nav_offers_url",
      "label": "Offers link"
    },
    {
      "type": "url",
      "id": "nav_learn_url",
      "label": "Learn link"
    },
    {
      "type": "url",
      "id": "nav_quiz_url",
      "label": "Hair Quiz link"
    },
    {
      "type": "url",
      "id": "nav_pros_url",
      "label": "Pros link"
    },
    {
      "type": "header",
      "content": "Page header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave empty to use the page title from Shopify."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introduction"
    }
  ],
  "blocks": [
    {
      "type": "section",
      "name": "Section",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Section title"
        },
        {
          "type": "html",
          "id": "body",
          "label": "Section body"
        }
      ]
    },
    {
      "type": "updated",
      "name": "Last updated",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Last updated text",
          "default": "Last Updated: July 2025"
        }
      ]
    },
    {
      "type": "closing",
      "name": "Closing contact",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Let's Stay Transparent"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email"
        },
        {
          "type": "text",
          "id": "whatsapp",
          "label": "WhatsApp"
        },
        {
          "type": "textarea",
          "id": "footer_note",
          "label": "Closing note"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ELARÉHAIR policy page"
    }
  ]
}
{% endschema %}
